{
    "name": "neudrino/stampy",
    "description": "Mailing-list plugin with double opt-in signup, subscriber/list management, a block-editor newsletter composer, SMTP delivery, and open/click tracking.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "mockery/mockery": "^1.6",
        "phpcsstandards/phpcsutils": "^1.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^9",
        "squizlabs/php_codesniffer": "^3.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3",
        "wp-phpunit/wp-phpunit": "^7.0",
        "yoast/phpunit-polyfills": "^4"
    },
    "autoload": {
        "psr-4": {
            "Stampy\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Stampy\\Tests\\": "tests/phpunit/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "analyse": "phpstan analyse --memory-limit=512M",
        "test:unit": "vendor/bin/phpunit --testsuite=unit",
        "test:integration": "STAMPY_TEST_INTEGRATION=1 vendor/bin/phpunit --testsuite=integration"
    }
}
