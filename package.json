{
	"name": "stampy",
	"version": "0.0.0",
	"private": true,
	"license": "GPL-3.0-only",
	"engines": {
		"node": ">=24"
	},
	"prettier": "@wordpress/prettier-config",
	"scripts": {
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style --allow-empty-input",
		"format": "wp-scripts format",
		"type-check": "tsc --noEmit",
		"test:unit:js": "wp-scripts test-unit-js --testPathIgnorePatterns=/node_modules/ --testPathIgnorePatterns=/tests/e2e/ --testPathIgnorePatterns=/.wp-env-home/",
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"env:start": "WP_ENV_HOME=./.wp-env-home wp-env start",
		"env:stop": "npm-run-all --continue-on-error --serial env:stop:wp env:stop:mailpit",
		"env:stop:wp": "WP_ENV_HOME=./.wp-env-home wp-env stop",
		"env:stop:mailpit": "bash ./dev/mailpit-down.sh",
		"env:destroy": "npm-run-all --continue-on-error --serial env:destroy:wp env:destroy:mailpit",
		"env:destroy:wp": "WP_ENV_HOME=./.wp-env-home wp-env destroy",
		"env:destroy:mailpit": "bash ./dev/mailpit-down.sh",
		"env:clean:tests": "WP_ENV_HOME=./.wp-env-home wp-env clean tests",
		"dev:start": "npm-run-all env:start start",
		"wp": "WP_ENV_HOME=./.wp-env-home wp-env run cli wp",
		"lint:php": "WP_ENV_HOME=./.wp-env-home wp-env run cli --env-cwd=wp-content/plugins/stampy composer lint",
		"analyse:php": "WP_ENV_HOME=./.wp-env-home wp-env run cli --env-cwd=wp-content/plugins/stampy composer analyse",
		"test:unit:php": "WP_ENV_HOME=./.wp-env-home wp-env run cli --env-cwd=wp-content/plugins/stampy composer test:unit",
		"test:integration:php": "WP_ENV_HOME=./.wp-env-home wp-env run tests-cli --env-cwd=wp-content/plugins/stampy composer test:integration",
		"test:e2e": "wp-scripts test-playwright",
		"validate:fast": "npm-run-all --continue-on-error lint:js lint:css type-check test:unit:js lint:php analyse:php test:unit:php",
		"validate:docker": "npm-run-all env:clean:tests --continue-on-error test:integration:php test:e2e",
		"validate": "npm-run-all env:start && npm-run-all --continue-on-error validate:fast && npm run validate:docker",
		"prepare": "husky"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@types/jest": "^30",
		"@types/wordpress__block-editor": "^15.0.6",
		"@wordpress/e2e-test-utils-playwright": "^1.51.0",
		"@wordpress/env": "^11.11.0",
		"@wordpress/scripts": "^33.0.0",
		"husky": "^9.1.7",
		"npm-run-all2": "^9",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"@wordpress/api-fetch": "^7.0.0",
		"@wordpress/blocks": "^15.0.0",
		"@wordpress/components": "^30.0.0",
		"@wordpress/i18n": "^6.0.0"
	},
	"dependencies": {
		"@types/papaparse": "^5.5.2",
		"papaparse": "^5.5.4"
	}
}
