{
	"name": "stampy",
	"version": "0.0.1",
	"private": true,
	"license": "GPL-2.0-or-later",
	"engines": {
		"node": ">=24"
	},
	"prettier": "@wordpress/prettier-config",
	"scripts": {
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style --allow-empty-input",
		"format": "wp-scripts format",
		"type-check": "tsc --noEmit",
		"test:unit:js": "wp-scripts test-unit-js",
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:destroy": "wp-env destroy",
		"env:clean:tests": "wp-env clean tests",
		"dev:start": "npm-run-all env:start start",
		"wp": "wp-env run cli wp",
		"lint:php": "wp-env run cli --env-cwd=wp-content/plugins/stampy composer lint",
		"analyse:php": "wp-env run cli --env-cwd=wp-content/plugins/stampy composer analyse",
		"test:unit:php": "wp-env run cli --env-cwd=wp-content/plugins/stampy composer test:unit",
		"test:integration:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/stampy composer test:integration",
		"test:e2e": "wp-scripts test-playwright",
		"validate:fast": "npm-run-all --continue-on-error lint:js lint:css type-check test:unit:js lint:php analyse:php test:unit:php",
		"validate:docker": "npm-run-all --continue-on-error test:integration:php test:e2e",
		"validate": "npm-run-all env:start && npm-run-all --continue-on-error validate:fast && npm run validate:docker",
		"prepare": "husky"
	},
	"devDependencies": {
		"@playwright/test": "^1",
		"@types/jest": "^30.0.0",
		"@types/wordpress__block-editor": "^11",
		"@wordpress/e2e-test-utils-playwright": "^1",
		"@wordpress/env": "^10",
		"@wordpress/scripts": "^30",
		"husky": "^9",
		"npm-run-all2": "^7",
		"typescript": "^5"
	}
}
